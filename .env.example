# Copie para ".env" (dev local) e configure os mesmos valores em
# Vercel > Project Settings > Environment Variables (produção).
# NUNCA commite o ".env" de verdade — só este ".env.example".

# App ID (Client ID) e Client Secret do app registrado em
# https://developers.mercadolivre.com.br/devcenter
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# Precisa bater exatamente com a "Redirect URI" cadastrada no app do
# Mercado Livre. Em produção: https://SEU-DOMINIO.vercel.app/api/auth/callback
ML_REDIRECT_URI=

# Preenchido automaticamente depois da autorização única (passo 3) —
# deixe em branco por enquanto.
ML_REFRESH_TOKEN=

# Projeto Supabase usado para login (contas de admin/cliente) e para as
# taxas de referência de marketplace (marketplace_rates) — NÃO guarda
# dado de produto/preço calculado. Pegue os três valores em Project
# Settings > API no painel do Supabase.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (Upstash) — sessões de login, tokens do Mercado Livre e o
# limitador de tentativas de login. Se o projeto Vercel já tem a
# integração Upstash ativada, `vercel env pull` traz isso automático;
# senão, pegue em Project Settings > Storage > (seu banco Upstash) > .env.
KV_REST_API_URL=
KV_REST_API_TOKEN=
